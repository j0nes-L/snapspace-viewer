---
const base = import.meta.env.BASE_URL;
const rendererUrl = `${base}scripts/renderer.js`;

const importMap = {
    "imports": {
        "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
        "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
    }
};
---
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quest 3 Scan Viewer</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: #1a1a1a; }
        #info {
            position: absolute;
            top: 10px;
            width: 100%;
            text-align: center;
            color: white;
            font-family: sans-serif;
            pointer-events: none;
            text-shadow: 1px 1px 2px black;
            z-index: 10;
        }
    </style>
    <script type="importmap" set:html={JSON.stringify(importMap)}></script>
</head>
<body>
    <div id="info">Loading point cloud...</div> 
    <script type="module" src={rendererUrl}></script>
</body>
</html>